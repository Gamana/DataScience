{
  "name": "Retail Corporate Blue",
  "dataColors": [
    "#0078D4",
    "#505050",
    "#2B88D8",
    "#107C10",
    "#D83B01",
    "#8764B8",
    "#00B7C3",
    "#FFB900",
    "#A80000",
    "#69797E"
  ],
  "foreground": "#252525",
  "background": "#FFFFFF",
  "tableAccent": "#0078D4",
  "good": "#107C10",
  "neutral": "#FFB900",
  "bad": "#D83B01",
  "maximum": "#0078D4",
  "center": "#505050",
  "minimum": "#D83B01",
  "textClasses": {
    "callout": {
      "fontSize": 28,
      "fontFace": "Segoe UI Semibold",
      "color": "#252525"
    },
    "title": {
      "fontSize": 12,
      "fontFace": "Segoe UI Semibold",
      "color": "#252525"
    },
    "header": {
      "fontSize": 12,
      "fontFace": "Segoe UI Semibold",
      "color": "#252525"
    },
    "label": {
      "fontSize": 10,
      "fontFace": "Segoe UI",
      "color": "#505050"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#E1E1E1" } },
            "radius": 8,
            "width": 1
          }
        ],
        "visualHeader": [
          {
            "show": true,
            "background": { "solid": { "color": "#FFFFFF" } },
            "border": { "solid": { "color": "#E1E1E1" } },
            "transparency": 0
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#252525" } },
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": { "solid": { "color": "#F3F3F3" } }
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#505050" } },
            "fontSize": 11,
            "fontFamily": "Segoe UI"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": { "solid": { "color": "#505050" } },
            "fontSize": 11
          }
        ],
        "wordWrap": [{ "show": true }]
      }
    },
    "slicer": {
      "*": {
        "items": [
          {
            "fontColor": { "solid": { "color": "#252525" } },
            "background": { "solid": { "color": "#FFFFFF" } }
          }
        ],
        "header": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#0078D4" } },
            "fontSize": 11,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#F5F7FA" } },
            "transparency": 0
          }
        ],
        "outspace": [
          {
            "color": { "solid": { "color": "#E8ECF0" } }
          }
        ]
      }
    }
  }
}
